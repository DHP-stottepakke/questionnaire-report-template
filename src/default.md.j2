* Project phase: **{{ dc.current_phase.title }}**
{%- endif %}
{%- if dc.project.project_tags|length > 0 %}
* Project tags: {% for tag in dc.project.project_tags %}**{{ tag }}**{% if not loop.last %}, {% endif %}{% endfor %}
{%- endif %}
{%- if dc.project.description %}
* Description: **{{ dc.project.description }}**
{%- endif %}
